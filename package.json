{
  "name": "frappe-wasm-playground",
  "version": "1.0.0",
  "description": "Frappe WASM Playground — Run Frappe Framework in the browser via Pyodide",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "build": "bash scripts/build.sh",
    "bundle": "bash scripts/bundle.sh",
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "debug:vfs": "node tests/debug/inspect_vfs.js",
    "debug:memory": "node tests/debug/inspect_memory.js"
  },
  "dependencies": {
    "express": "^4.22.2",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
