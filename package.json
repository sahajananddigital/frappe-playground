{
  "name": "frappe-playground",
  "version": "1.0.0",
  "description": "Run Frappe Framework in the browser via Pyodide",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:preview": "vite preview --host 0.0.0.0",
    "start": "npm run dev:preview",
    "build": "vite build",
    "build:runtime": "bash scripts/build.sh",
    "deploy:prepare": "bash scripts/prepare-deploy.sh",
    "predeploy": "npm run deploy:prepare",
    "deploy": "bash scripts/deploy.sh",
    "test": "npm run test:e2e",
    "test:e2e": "playwright test tests/e2e --project=chromium --project=webkit"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.14",
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "frappe-ui": "^0.1.278",
    "vue": "^3.5.35"
  }
}
